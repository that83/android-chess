<?xml version="1.0" encoding="utf-8"?>
<!-- Landscape: board + first 2 control rows on left; training/status content on right. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="4dip">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.3"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:layout_marginBottom="2dp">

            <include
                android:id="@+id/includeboard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/EvalBar"
                android:layout_marginStart="4dp"
                layout="@layout/chessboard" />

            <jwtc.android.chess.views.EvalBarView
                android:id="@+id/EvalBar"
                android:layout_width="10dp"
                android:layout_height="0dp"
                android:layout_alignParentStart="true"
                android:layout_alignTop="@id/includeboard"
                android:layout_alignBottom="@id/includeboard"
                android:layout_marginEnd="4dp" />

            <jwtc.android.chess.views.OpeningLineProgressView
                android:id="@+id/OpeningLineProgress"
                android:layout_width="wrap_content"
                android:layout_height="10dp"
                android:layout_below="@id/includeboard"
                android:layout_alignStart="@id/includeboard"
                android:layout_alignEnd="@id/includeboard"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/TextViewLineDoneOverlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignTop="@id/includeboard"
                android:layout_alignBottom="@id/includeboard"
                android:layout_alignStart="@id/includeboard"
                android:layout_alignEnd="@id/includeboard"
                android:gravity="center"
                android:text="WELLDONE!!"
                android:textStyle="bold"
                android:textSize="34sp"
                android:textColor="#FFFFFFFF"
                android:shadowColor="#CC000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"
                android:visibility="gone" />

            <TextView
                android:id="@+id/TextViewFenTurnFlash"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignTop="@id/includeboard"
                android:layout_alignBottom="@id/includeboard"
                android:layout_alignStart="@id/includeboard"
                android:layout_alignEnd="@id/includeboard"
                android:gravity="center"
                android:textStyle="bold"
                android:textSize="36sp"
                android:textColor="#FFF8FFCC"
                android:shadowColor="#EE000000"
                android:shadowDx="0"
                android:shadowDy="3"
                android:shadowRadius="8"
                android:visibility="gone" />
        </RelativeLayout>

        <TableLayout
            android:id="@+id/LayoutEngineInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="1">

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/MyRowStyle">
                <RelativeLayout
                    android:id="@+id/LayoutPlayButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageButton
                        android:id="@+id/ButtonPlay"
                        android:src="@drawable/ic_robot"
                        android:contentDescription="@string/button_engine_play_description"
                        style="@style/ChessImageButton" />

                    <ProgressBar
                        android:id="@+id/ProgressBarPlay"
                        android:layout_width="40dip"
                        android:layout_height="40dip"
                        style="?android:attr/progressBarStyleLarge"
                        android:visibility="gone" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/TextViewLastMove"
                    style="@style/MyPaneTextStyle"
                    android:layout_width="0dp"
                    android:layout_weight="2"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dip"
                    android:layout_marginRight="8dip"
                    android:accessibilityLiveRegion="assertive" />

                <ImageButton
                    android:id="@+id/ButtonMenu"
                    android:src="@drawable/ic_three_dots_vertical"
                    android:contentDescription="@string/button_menu_description"
                    style="@style/ChessImageButton" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/MyRowStyle">
                <ImageButton
                    android:id="@+id/ButtonPrevious"
                    android:src="@drawable/ic_chevron_left"
                    android:contentDescription="@string/button_previous_move_description"
                    style="@style/ChessImageButton" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/HistoryRecyclerView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="8dip"
                    android:layout_marginRight="8dip"
                    android:orientation="horizontal"
                    android:scrollbars="horizontal"
                    android:fadeScrollbars="false"
                    android:background="@color/paneBackgroundColor"
                    android:scrollbarAlwaysDrawHorizontalTrack="true" />
                <ImageButton
                    android:id="@+id/ButtonNext"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="@string/button_next_move_description"
                    style="@style/ChessImageButton" />
            </TableRow>
        </TableLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.0"
        android:layout_marginStart="8dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/SwitchShowGuide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/opening_trainer_show_guide"
                android:checked="false"
                android:visibility="gone" />

            <TextView
                android:id="@+id/TextViewOpeningBookComment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="4dp"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:visibility="gone" />

            <include layout="@layout/opening_trainer_controls" />

            <LinearLayout
                android:id="@+id/OpeningTrainerControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:paddingTop="4dp">

                <Button
                    android:id="@+id/ButtonOpeningHint"
                    style="@style/ChessButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/opening_trainer_hint" />

                <Button
                    android:id="@+id/ButtonOpeningUndo"
                    style="@style/ChessButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="4dp"
                    android:visibility="gone"
                    android:text="@string/opening_trainer_undo" />

                <Button
                    android:id="@+id/ButtonOpeningRestart"
                    style="@style/ChessButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="4dp"
                    android:text="@string/opening_trainer_restart" />

                <Button
                    android:id="@+id/ButtonOpeningExit"
                    style="@style/ChessButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="4dp"
                    android:text="@string/opening_trainer_exit" />
            </LinearLayout>

            <TextView
                android:id="@+id/TextViewOpeningTrainerStudyLine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:text="@string/opening_trainer_study_line_label"
                android:visibility="gone"
                android:paddingTop="6dp"
                android:paddingBottom="2dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:fillViewport="false">

                <LinearLayout
                    android:id="@+id/OpeningTrainerStudyLineControls"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="2dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/SwitchAutoNext"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="4dp"
                        android:text="@string/opening_trainer_auto_next"
                        android:checked="true"/>

                    <Button
                        android:id="@+id/ButtonOpeningNextLine"
                        style="@style/ChessButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="4dp"
                        android:text="@string/opening_trainer_next"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/SwitchShuffleLines"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="4dp"
                        android:text="@string/opening_trainer_shuffle"
                        android:checked="false"/>

                    <Button
                        android:id="@+id/ButtonSelectChapters"
                        style="@style/ChessButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="4dp"
                        android:minHeight="48dp"
                        android:maxLines="1"
                        android:gravity="center"
                        android:ellipsize="end"
                        android:text="@string/opening_trainer_select_chapters"
                        android:visibility="gone"/>
                </LinearLayout>
            </HorizontalScrollView>

            <ScrollView
                android:id="@+id/ScrollViewOpeningTrainerStatus"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="6dp"
                android:fillViewport="true"
                android:nestedScrollingEnabled="true"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/TextViewOpeningTrainerStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:text="@string/opening_trainer_status_initial"
                    android:paddingTop="6dp"
                    android:paddingBottom="4dp" />
            </ScrollView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
