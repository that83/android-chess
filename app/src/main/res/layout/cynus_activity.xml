<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cynus_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/cynus_intro"
        android:textAppearance="?android:attr/textAppearanceSmall" />

    <!-- Buttons on one row; switches on the next — avoids horizontal overflow on phones. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="8dp">

        <Button
            android:id="@+id/ButtonCynusScan"
            style="@style/ChessButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cynus_scan" />

        <Button
            android:id="@+id/ButtonCynusDisconnect"
            style="@style/ChessButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:enabled="false"
            android:text="@string/cynus_disconnect" />

        <Button
            android:id="@+id/ButtonCynusExportPgn"
            style="@style/ChessButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/cynus_export_pgn" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="4dp">

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/SwitchCynusAppEngine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="false"
            android:enabled="false"
            android:text="@string/cynus_app_engine"
            app:useMaterialThemeColors="true" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/SwitchCynusFlipBoard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:checked="false"
            android:enabled="false"
            android:text="@string/cynus_flip_board"
            app:useMaterialThemeColors="true" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:text="@string/cynus_devices"
        android:textStyle="bold" />

    <ListView
        android:id="@+id/ListViewCynusDevices"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="120dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="8dp"
        android:text="@string/cynus_log"
        android:textStyle="bold" />

    <ScrollView
        android:id="@+id/ScrollViewCynusLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="160dp"
        android:fillViewport="true">

        <TextView
            android:id="@+id/TextViewCynusLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textIsSelectable="true"
            android:typeface="monospace"
            android:textAppearance="?android:attr/textAppearanceSmall" />
    </ScrollView>
</LinearLayout>
